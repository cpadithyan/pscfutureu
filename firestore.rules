rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Study content: any signed-in student can read.
    // Writes are blocked here — your admin panel uses the ADMIN_PASSCODE
    // gate in the app, not Firebase Auth, so for now content writes
    // should go through the Firebase Console or a trusted admin script.
    // (Ask me if you want the admin panel itself to write through
    // Firebase Auth with an "isAdmin" custom claim instead — more secure.)
    match /videos/{id}  { allow read: if request.auth != null; allow write: if false; }
    match /pdfs/{id}    { allow read: if request.auth != null; allow write: if false; }
    match /quizzes/{id} { allow read: if request.auth != null; allow write: if false; }
    match /exams/{id}   { allow read: if request.auth != null; allow write: if false; }

    // Students can only read/write their own profile document.
    match /students/{phone} {
      allow read, write: if request.auth != null
        && request.auth.token.phone_number == "+91" + phone;
    }

    // Students can create their own results and read only their own.
    // (Firestore rules can't strip the "+91" prefix, so we compare by
    // adding it back to the stored phone instead.)
    match /results/{resultId} {
      allow create: if request.auth != null
        && "+91" + request.resource.data.studentPhone == request.auth.token.phone_number;
      allow read: if request.auth != null
        && "+91" + resource.data.studentPhone == request.auth.token.phone_number;
      allow update, delete: if false;
    }
  }
}
